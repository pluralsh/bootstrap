apiVersion: logstash.k8s.elastic.co/v1alpha1
kind: Logstash
metadata:
  name: logstash
spec:
  count: 1
  version: 8.16.0
  elasticsearchRefs:
  - clusterName: upstream
    secretName: upstream-es-ref
  podTemplate:
    containers:
    - name: logstash
      resources:
        requests:
          memory: 1Gi
          cpu: 500m
  pipelines:
    - pipeline.id: main
      # Defaults are 125 / 50ms; raise both to batch more events per cycle (fewer ES bulks, slightly higher latency).
      pipeline.batch.size: 200
      pipeline.batch.delay: 150
      config.string: |
        input {
          beats {
            port => 5044
          }
        }
        filter {
          age {}
          if [@metadata][age] > 86400 {
            drop {}
          }
          grok {
            match => { "message" => "%{HTTPD_COMMONLOG}"}
          }
          geoip {
            source => "[source][address]"
            target => "[source]"
          }
        }
        output {
          elasticsearch {   
            hosts => [ "${UPSTREAM_ES_HOSTS}" ]
            user => "${UPSTREAM_ES_USER}"
            password => "${UPSTREAM_ES_PASSWORD}"
            index => "{{ contexts["plrl/cloud/observability"].elastic.user }}-logs-%{+YYYY.MM.dd}"
            manage_template => false
            # Longer timeout while ES is under merge/ILM load (default 60s).
            timeout => 120
            retry_max_interval => 120
          }
        }
  services:
    - name: beats
      service:
        spec:
          type: ClusterIP
          ports:
            - port: 5044
              name: "filebeat"
              protocol: TCP
              targetPort: 5044